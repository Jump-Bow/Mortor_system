# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
 
# Development Database (PostgreSQL)
DEV_DB_SERVER=localhost
DEV_DB_PORT=5432
DEV_DB_NAME=fem_dev
DEV_DB_USER=fem_admin
DEV_DB_PASSWORD=your-dev-db-password
 
# Production Database (PostgreSQL)
PROD_DB_SERVER=your-pg-host
PROD_DB_PORT=5432
PROD_DB_NAME=fem_prod
PROD_DB_USER=fem_admin
PROD_DB_PASSWORD=your-prod-db-password
 
# Azure Entra ID (Azure AD)
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
 
# AIMS Integration
AIMS_API_URL=https://aims.example.com/api
AIMS_API_KEY=your-aims-api-key
 
# Redis (Production Only)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
 
# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-east1
GCP_BUCKET_NAME=fem-uploads
 
 
# Development Mode - Using Mock Data (No Database Required)
USE_MOCK_DATA=true
MOCK_DATA_PATH=./data/mock_data.json
 
# Development Database (SQLite for local testing)
DEV_DB_TYPE=sqlite
DEV_DB_PATH=./data/fem_dev.db

# 本地開發停用 Redis 相關功能（無需安裝 Redis）
TOKEN_BLACKLIST_ENABLED=false
RATELIMIT_ENABLED=false